{
  "PackageInformation": {
    "SetupType": "MSI",
    "SetupFile": "Deploy-Application.exe",
    "SourceFolder": "Source",
    "OutputFolder": "Package",
    "Version": "25.01",
    "SourceURL": "https://www.7-zip.org",
    "IconFile": "Icon.png"
  },
  "Information": {
    "DisplayName": "7-Zip",
    "AppVersion": "25.01",
    "Description": "7-Zip is a file archiver with a high compression ratio",
    "Publisher": "Igor Pavlov",
    "Developer": "Igor Pavlov",
    "CompanyPortalFeaturedApp": "false",
    "InformationURL": "https://www.7-zip.org",
    "PrivacyURL": "https://www.7-zip.org",
    "Notes": "File archiver utility"
  },
  "Program": {
    "InstallCommand": "Deploy-Application.exe install",
    "UninstallCommand": "Deploy-Application.exe uninstall",
    "InstallExperience": "system",
    "DeviceRestartBehavior": "suppress"
  },
  "RequirementRule": {
    "MinimumRequiredOperatingSystem": "W10_22H2",
    "Architecture": "x64"
  },
  "DetectionRule": [
    {
      "DetectionType": "File",
      "Path": "C:\\Program Files\\7-Zip",
      "FileOrFolderName": "7z.exe",
      "FileDetectionType": "exists",
      "check32BitOn64System": "false"
    }
  ],
  "Assignment": [
    {
      "Target": "AllUsers",
      "Intent": "available",
      "Notification": "showAll"
    }
  ]
}