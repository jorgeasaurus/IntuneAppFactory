{
  "PackageInformation": {
    "SetupType": "EXE",
    "SetupFile": "Invoke-AppDeployToolkit.exe",
    "IconFile": "Icon.png"
  },
  "Information": {
    "DisplayName": "Citrix Workspace",
    "Description": "Citrix Workspace app for accessing virtual apps and desktops",
    "Publisher": "Citrix",
    "Developer": "Cloud Software Group, Inc.",
    "InformationURL": "https://www.citrix.com/products/receiver.html",
    "PrivacyURL": "https://www.cloud.com/privacy-policy"
  },
  "Program": {
    "InstallCommand": "Invoke-AppDeployToolkit.exe -DeploymentType Install",
    "UninstallCommand": "Invoke-AppDeployToolkit.exe -DeploymentType Uninstall",
    "InstallExperience": "system",
    "DeviceRestartBehavior": "suppress"
  },
  "RequirementRule": {
    "MinimumRequiredOperatingSystem": "W10_22H2",
    "Architecture": "x64"
  },
  "DetectionRule": [
    {
      "DetectionType": "File",
      "Path": "C:\\Program Files (x86)\\Citrix\\ICA Client",
      "FileOrFolderName": "wfica32.exe",
      "FileDetectionType": "exists"
    }
  ],
  "Assignment": [
    {
      "Target": "AllUsers",
      "Intent": "available",
      "Notification": "showAll"
    }
  ]
}
