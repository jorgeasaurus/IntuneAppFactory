{
  "PackageInformation": {
    "SetupType": "MSI",
    "SetupFile": "Invoke-AppDeployToolkit.exe",
    "IconFile": "Icon.png"
  },
  "Information": {
    "DisplayName": "Microsoft Edge",
    "Description": "Chromium-based web browser by Microsoft",
    "Publisher": "Microsoft",
    "Developer": "Microsoft Corporation",
    "InformationURL": "https://www.microsoft.com/edge",
    "PrivacyURL": "https://privacy.microsoft.com/"
  },
  "Program": {
    "InstallCommand": "Invoke-AppDeployToolkit.exe -DeploymentType Install",
    "UninstallCommand": "Invoke-AppDeployToolkit.exe -DeploymentType Uninstall",
    "InstallExperience": "system",
    "DeviceRestartBehavior": "suppress"
  },
  "RequirementRule": {
    "MinimumRequiredOperatingSystem": "W10_22H2",
    "Architecture": "x64"
  },
  "DetectionRule": [
    {
      "DetectionType": "File",
      "Path": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application",
      "FileOrFolderName": "msedge.exe",
      "FileDetectionType": "exists"
    }
  ],
  "Assignment": [
    {
      "Target": "AllUsers",
      "Intent": "available",
      "Notification": "showAll"
    }
  ]
}
