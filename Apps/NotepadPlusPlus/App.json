{
  "PackageInformation": {
    "SetupType": "EXE",
    "SetupFile": "Invoke-AppDeployToolkit.exe",
    "SourceFolder": "Source",
    "OutputFolder": "Package",
    "Version": "8.8.3",
    "SourceURL": "https://notepad-plus-plus.org",
    "IconFile": "Icon.png"
  },
  "Information": {
    "DisplayName": "Notepad++",
    "AppVersion": "8.8.3",
    "Description": "Notepad++ is a free source code editor and Notepad replacement",
    "Publisher": "Don Ho",
    "Developer": "Don Ho",
    "CompanyPortalFeaturedApp": "false",
    "InformationURL": "https://notepad-plus-plus.org",
    "PrivacyURL": "https://notepad-plus-plus.org",
    "Notes": "Free source code editor"
  },
  "Program": {
    "InstallCommand": "Invoke-AppDeployToolkit.exe -DeploymentType Install",
    "UninstallCommand": "Invoke-AppDeployToolkit.exe -DeploymentType Uninstall",
    "InstallExperience": "system",
    "DeviceRestartBehavior": "suppress"
  },
  "RequirementRule": {
    "MinimumRequiredOperatingSystem": "W10_22H2",
    "Architecture": "x64"
  },
  "DetectionRule": [
    {
      "DetectionType": "Registry",
      "KeyPath": "HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Notepad++",
      "ValueName": "DisplayVersion",
      "RegistryDetectionType": "versionComparison",
      "Operator": "greaterThanOrEqual",
      "Value": "8.8.3",
      "check32BitOn64System": "true"
    }
  ],
  "Assignment": [
    {
      "Target": "AllUsers",
      "Intent": "available",
      "Notification": "showAll",
      "AvailableTime": "",
      "DeadlineTime": "",
      "UseLocalTime": "true",
      "DeliveryOptimizationPriority": "notConfigured",
      "EnableRestartGracePeriod": "false",
      "RestartGracePeriod": "",
      "RestartCountDownDisplay": "",
      "RestartNotificationSnooze": ""
    }
  ]
}
